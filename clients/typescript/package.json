{
  "name": "@grpc-webnext/client",
  "version": "0.1.0",
  "description": "grpc-webnext TypeScript client (browser + node): Fetch unary, WebSocket streaming.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "gen": "protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/generated --ts_proto_opt=esModuleInterop=true,forceLong=long,outputServices=generic-definitions,useExactTypes=false -I ../../proto ../../proto/grpc_webnext.proto",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.1",
    "long": "^5.2.3"
  },
  "devDependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@types/ws": "^8.5.12",
    "ts-proto": "^2.6.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "ws": "^8.18.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "protobufjs@7.6.4": true
  }
}
