{
  "name": "@grpc-webnext/client",
  "version": "0.1.0",
  "description": "Full bidirectional gRPC client for the browser and Node — real HTTP/2 tunneled over WebSockets via h2ts, plus JSON over Fetch + WebSocket.",
  "license": "MIT OR Apache-2.0",
  "author": "Debdatta Basu",
  "homepage": "https://github.com/debdattabasu/grpc_webnext#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/debdattabasu/grpc_webnext.git",
    "directory": "node/packages/client"
  },
  "bugs": {
    "url": "https://github.com/debdattabasu/grpc_webnext/issues"
  },
  "keywords": [
    "grpc",
    "grpc-web",
    "http2",
    "websocket",
    "h2ts",
    "browser",
    "rpc",
    "protobuf",
    "streaming",
    "fetch"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "scripts": {
    "gen": "protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/generated --ts_proto_opt=esModuleInterop=true,forceLong=long,outputServices=generic-definitions,useExactTypes=false -I ../../../proto ../../../proto/grpc_webnext.proto",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx examples/greeter.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.1",
    "@debdattabasu/h2ts": "0.1.1",
    "long": "^5.2.3"
  },
  "devDependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@types/js-yaml": "^4.0.9",
    "@types/ws": "^8.5.12",
    "js-yaml": "^5.2.1",
    "ts-proto": "^2.6.0",
    "tsx": "^4.22.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "ws": "^8.18.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "protobufjs@7.6.4": true,
    "esbuild@0.28.1": true
  }
}
